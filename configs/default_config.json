{
  "app_name": "XSS Security GUI",
  "version": "6.5.0",

  "network": {
    "default_timeout": 8,
    "max_rps": 10,
    "retry_total": 7,
    "retry_backoff": 0.5,
    "proxies": {}
  },

  "logging": {
    "level": "INFO",
    "file": "logs/app.log",
    "init_file": "logs/init.log",
    "format": "%(asctime)s [%(levelname)s] %(message)s"
  },

  "scanner": {
    "payload_category_default": "basic",
    "payload_sources": [
      "manual_json",
      "category",
      "resources/payloads.json"
    ],
    "save_full_responses": true,
    "response_dir": "logs/responses",
    "summary_dir": "logs"
  },

  "gui": {
    "theme": "default",
    "language": "ru",
    "autosave": true,
    "show_progress_bar": true
  },

  "dependencies": {
    "ngrok_required": false,
    "check_libraries": [
      "requests",
      "tkinter",
      "urllib3"
    ]
  },

  "honeypot": {
    "enable": true,
    "poll_interval": 4,
    "log_path": "logs/honeypot.log",
    "hits_log_path": "logs/honeypot_hits.log"
  },

  "http": {
    "request_timeout": 7,
    "default_user_agent": "XSS-Security-GUI/6.5"
  },

  "idor": {
    "delay": 0.5
  },

  "lfi": {
    "delay": 0.5,
    "payloads": [
      "../../etc/passwd",
      "../../../etc/passwd",
      "../../../../etc/passwd",
      "..%2f..%2fetc%2fpasswd",
      "..\\\\..\\\\windows\\\\win.ini",
      "/etc/passwd",
      "..%252f..%252fetc%252fpasswd"
    ],
    "signatures": [
      "root:x",
      "[extensions]",
      "[fonts]",
      "[drivers]"
    ]
  },

  "sqli": {
    "error_indicators": [
      "sql syntax", "mysql", "postgres", "sqlite", "odbc",
      "warning", "fatal error", "unclosed quotation mark",
      "unexpected end of input", "query failed",
      "native client", "syntax error", "invalid query",
      "unexpected token", "unterminated string", "invalid column"
    ],
    "waf_indicators": [
      "waf", "blocked", "forbidden", "security", "mod_security",
      "access denied", "firewall", "request rejected"
    ]
  },

  "ssrf": {
    "body_indicators": [
      "169.254.", "metadata", "ec2", "internal", "localhost", "127.0.0.1",
      "google.internal", "azure", "gcp", "aws", "openstack",
      "file://", "ftp://", "unix://"
    ],
    "header_indicators": [
      "via", "x-forwarded-for", "x-aws-", "metadata", "x-real-ip"
    ]
  },

  "payloads": {
    "sqli_file": "payloads/sqli.json",
    "xss_file": "payloads/xss.json",
    "ssrf_file": "payloads/ssrf.json"
  },

  "threat": {
    "artifact_path": "logs/threat_intel_artifact.json",
    "log_path": "logs/threat_intel.log",
    "max_size_mb": 20
  },

  "export": {
    "max_line_length": 110
  }
}